{
  "name": "praana",
  "version": "0.8.0",
  "description": "Terminal coding agent with adaptive context and cross-session memory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amitkumardubey/praana.git"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "terminal",
    "assistant",
    "llm"
  ],
  "type": "module",
  "bin": {
    "praana": "bin/praana.js",
    "pran": "bin/pran.js"
  },
  "files": [
    "bin",
    "dist",
    "praana.config.example.toml"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^11.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cliui": "^9.0.1",
    "compromise": "^14.15.1",
    "ink": "^7.0.5",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.2.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "ora": "^9.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "react": "^19.2.7",
    "sqlite-vec": "^0.1.6",
    "strip-ansi": "^7.2.0",
    "toml": "^3.0.0",
    "ulid": "^2.3.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  }
}
