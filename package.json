{
  "name": "praana",
  "version": "0.9.0",
  "description": "Terminal coding agent with adaptive context and cross-session memory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amitkumardubey/praana.git"
  },
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "terminal",
    "assistant",
    "llm"
  ],
  "type": "module",
  "bin": {
    "praana": "bin/praana.js",
    "pran": "bin/pran.js"
  },
  "files": [
    "bin",
    "src",
    "praana.config.example.toml"
  ],
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "typecheck": "tsc",
    "start": "bun src/main.ts",
    "dev": "bun src/main.ts",
    "test": "bun test tests/",
    "test:watch": "bun test --watch tests/",
    "test:coverage": "bun test --coverage tests/",
    "verify:sqlite-vec": "bun run scripts/verify-sqlite-vec.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@huggingface/transformers": "^4.2.0",
    "ansi-styles": "^4.3.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "cliui": "^9.0.1",
    "compromise": "^14.15.1",
    "js-yaml": "^4.3.0",
    "ora": "^9.4.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "sqlite-vec": "^0.1.9",
    "strip-ansi": "^7.2.0",
    "toml": "^3.0.0",
    "ulid": "^2.4.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
